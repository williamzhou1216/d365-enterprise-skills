{
  "name": "d365-delivery-harness",
  "version": "1.0.0",
  "defaultProfileEnv": "D365_PROFILE",
  "connectionsFileEnv": "D365_CONNECTIONS_FILE",
  "artifactsRoot": "artifacts",
  "description": "Delivery execution harness for Dynamics CRM / D365 / Power Platform projects running through OpenCode and d365-mcp.",
  "entrypoints": {
    "powershell": "harness/scripts/invoke-harness.ps1",
    "shell": "harness/scripts/invoke-harness.sh",
    "operatorGuide": "harness/EXECUTION.md"
  },
  "securityRules": [
    "Treat all production environments as read-only by default.",
    "Honor profile readonly before any write-class action.",
    "Never commit secret, password, token, client secret, or connection string values.",
    "Do not execute production write operations without explicit user confirmation.",
    "Prefer d365-mcp metadata reads before design or implementation changes.",
    "Prefer pac CLI for solution packaging and PCF lifecycle operations.",
    "On-Premises AD, ADFS, and IFD projects must document connector and protocol differences.",
    "All workflow outputs must be delivery-ready and traceable to inputs and environment assumptions."
  ],
  "workflowOrder": [
    "requirementAnalysis",
    "fitGapAnalysis",
    "pluginDevelopment",
    "webresourceDevelopment",
    "pcfDevelopment",
    "powerAutomate",
    "solutionRelease",
    "uatTesting",
    "securityMatrix",
    "cutoverPlan",
    "productionSupport"
  ],
  "artifactsConvention": {
    "description": "Workflow outputs are written under artifacts/<workflow-folder>/ with stable delivery filenames.",
    "rules": [
      "Keep one top-level artifact folder per workflow.",
      "Store machine-generated evidence in subfolders like test-results or build-output.",
      "Do not write secrets, passwords, tokens, or raw connection exports into artifacts.",
      "Prefer Markdown for customer-facing deliverables and plain folders for test/build evidence.",
      "Record all created or modified artifact files in the final execution summary."
    ]
  },
  "workflows": {
    "requirementAnalysis": {
      "file": "workflows/requirement-analysis.workflow.md",
      "requiredTools": [
        "d365_get_current_profile",
        "d365_test_connection",
        "d365_list_entities",
        "d365_get_entity_metadata",
        "d365_list_forms",
        "d365_get_form_configuration",
        "d365_list_views",
        "d365_generate_field_dictionary",
        "d365_generate_solution_design_doc"
      ],
      "qualityGates": [
        "security.gate.md",
        "production-safety.gate.md"
      ],
      "outputPaths": [
        "artifacts/requirement-analysis/requirements-summary.md",
        "artifacts/requirement-analysis/assumptions.md",
        "artifacts/requirement-analysis/entity-scope.md"
      ],
      "requiresPacCli": false,
      "requiresDotnetBuild": false,
      "requiresNpmBuild": false,
      "writeAccess": "none"
    },
    "fitGapAnalysis": {
      "file": "workflows/fit-gap-analysis.workflow.md",
      "requiredTools": [
        "d365_get_current_profile",
        "d365_test_connection",
        "d365_list_entities",
        "d365_get_entity_metadata",
        "d365_get_option_set",
        "d365_list_relationships",
        "d365_generate_fit_gap_analysis"
      ],
      "qualityGates": [
        "security.gate.md",
        "production-safety.gate.md"
      ],
      "outputPaths": [
        "artifacts/fit-gap-analysis/fit-gap-analysis.md",
        "artifacts/fit-gap-analysis/decision-log.md"
      ],
      "requiresPacCli": false,
      "requiresDotnetBuild": false,
      "requiresNpmBuild": false,
      "writeAccess": "none"
    },
    "pluginDevelopment": {
      "file": "workflows/plugin-development.workflow.md",
      "requiredTools": [
        "d365_get_current_profile",
        "d365_test_connection",
        "d365_get_entity_metadata",
        "d365_get_attribute_metadata",
        "d365_list_relationships",
        "d365_list_plugin_steps",
        "d365_analyze_plugin_code",
        "d365_generate_plugin_template",
        "d365_generate_plugin_registration_note"
      ],
      "qualityGates": [
        "code-quality.gate.md",
        "d365-plugin.gate.md",
        "security.gate.md",
        "production-safety.gate.md"
      ],
      "outputPaths": [
        "artifacts/plugin-development/plugin-design.md",
        "artifacts/plugin-development/plugin-registration.md",
        "artifacts/plugin-development/test-results/"
      ],
      "requiresPacCli": false,
      "requiresDotnetBuild": true,
      "requiresNpmBuild": false,
      "writeAccess": "local-code-only"
    },
    "webresourceDevelopment": {
      "file": "workflows/webresource-development.workflow.md",
      "requiredTools": [
        "d365_get_current_profile",
        "d365_test_connection",
        "d365_list_webresources",
        "d365_list_forms",
        "d365_get_form_configuration",
        "d365_get_entity_metadata",
        "d365_get_attribute_metadata",
